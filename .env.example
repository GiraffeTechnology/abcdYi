# Database
DATABASE_URL=postgresql+asyncpg://giraffe:giraffe@localhost:5432/apparel_textile

# Auth
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM (optional — system works without LLM provider)
LLM_PROVIDER=stub
OPENAI_API_KEY=
QWEN_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO

# GPM (Giraffe Pricing Model) — internal service running on feature/giraffe-pricing-model branch
# abcdyi calls GPM via HTTP; it never accesses GPM's DB tables directly
GPM_SERVICE_URL=http://localhost:8001
GPM_SERVICE_API_KEY=change-me-gpm-internal-key
