# Database
DATABASE_URL=postgresql+asyncpg://giraffe:giraffe@localhost:5432/apparel_textile

# Auth
# SECRET_KEY MUST be overridden in production with a long random string
# (>= 32 chars). The API fails fast on startup if this placeholder value or
# any value shorter than 32 characters is used. Generate one with, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM (optional — system works without LLM provider)
LLM_PROVIDER=stub
OPENAI_API_KEY=
QWEN_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
